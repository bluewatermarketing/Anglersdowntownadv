# Anthropic API key — used by `npm run draft "<topic>"` to generate
# blog post drafts. Get a key at https://console.anthropic.com/
#
# To use:  1. Copy this file to .env.local  (which is gitignored)
#          2. Replace the placeholder with your real key
#          3. Run:  npm run draft "your topic here"
ANTHROPIC_API_KEY=sk-ant-your-key-here
